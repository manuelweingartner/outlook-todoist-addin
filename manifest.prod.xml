<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
  <Id>74742003-707d-4555-ae88-30e2fef7db9c</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Manuel Weingartner</ProviderName>
  <DefaultLocale>de-DE</DefaultLocale>
  <DisplayName DefaultValue="Mail an Todoist"/>
  <Description DefaultValue="Oeffnet eine Seitenleiste zum Anhaengen der aktuellen Mail als .eml-Datei an einen Todoist-Task."/>
  <IconUrl DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://github.com/manuelweingartner/outlook-todoist-addin"/>
  <AppDomains>
    <AppDomain>https://api.todoist.com</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.8">
      <Set Name="Mailbox" MinVersion="1.8"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.8">
        <bt:Set Name="Mailbox" MinVersion="1.8"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="ActionButton">
                  <Label resid="ActionButton.Label"/>
                  <Supertip>
                    <Title resid="ActionButton.Label"/>
                    <Description resid="ActionButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>action</FunctionName>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://manuelweingartner.github.io/outlook-todoist-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Todoist"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="An Todoist-Task"/>
        <bt:String id="ActionButton.Label" DefaultValue="An Todoist-Task"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Mail als .eml-Datei an einen Todoist-Task anhaengen."/>
        <bt:String id="ActionButton.Tooltip" DefaultValue="Mail als .eml-Datei an einen Todoist-Task anhaengen."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
